---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Directory Publisher | Texoma Weekend Guide"
  description="Private publishing utility for the Texoma Weekend Guide business directory."
>
  <section class="publisher">
    <header>
      <p class="eyebrow">TWG Admin</p>
      <h1>Directory JSON Publisher</h1>
      <p>Paste the complete directory JSON, validate it, then publish it directly to GitHub.</p>
    </header>

    <div class="panel">
      <label for="admin-key">Admin key</label>
      <input
        id="admin-key"
        type="password"
        autocomplete="current-password"
        placeholder="Enter your private publishing key"
      />

      <label for="json-input">Directory JSON</label>
      <textarea
        id="json-input"
        spellcheck="false"
        autocapitalize="off"
        autocomplete="off"
        placeholder='Paste the complete JSON here, beginning with { and ending with }'
      ></textarea>

      <div class="actions">
        <button id="load-current" type="button" class="secondary">Load current JSON</button>
        <button id="validate" type="button">Validate JSON</button>
        <button id="publish" type="button" disabled>Publish</button>
      </div>

      <section id="results" class="results" aria-live="polite">
        <h2>Validation status</h2>
        <p id="status">Nothing has been validated yet.</p>
        <ul id="checks"></ul>
      </section>
    </div>
  </section>

  <script>
    const input = document.querySelector("#json-input");
    const adminKey = document.querySelector("#admin-key");
    const status = document.querySelector("#status");
    const checks = document.querySelector("#checks");
    const validateButton = document.querySelector("#validate");
    const loadButton = document.querySelector("#load-current");
    const publishButton = document.querySelector("#publish");

    if (
      !(input instanceof HTMLTextAreaElement) ||
      !(adminKey instanceof HTMLInputElement) ||
      !(status instanceof HTMLElement) ||
      !(checks instanceof HTMLUListElement) ||
      !(validateButton instanceof HTMLButtonElement) ||
      !(loadButton instanceof HTMLButtonElement) ||
      !(publishButton instanceof HTMLButtonElement)
    ) {
      throw new Error("Directory publisher controls could not be initialized.");
    }

    let validatedJson = null;

    const setResult = (message, items = [], valid = false) => {
      status.textContent = message;
      status.className = valid ? "success" : "error";
      checks.replaceChildren();

      for (const item of items) {
        const li = document.createElement("li");
        li.textContent = item;
        checks.appendChild(li);
      }
    };

    const validateDirectory = () => {
      validatedJson = null;
      publishButton.disabled = true;

      try {
        const data = JSON.parse(input.value);

        if (!data || typeof data !== "object" || Array.isArray(data)) {
          throw new Error("The top level must be a JSON object.");
        }

        if (!Array.isArray(data.businesses)) {
          throw new Error('The JSON must contain a "businesses" array.');
        }

        const missingNames = data.businesses.filter(
          (business) => !business?.business_name || typeof business.business_name !== "string"
        );
        const missingSlugs = data.businesses.filter(
          (business) => !business?.slug || typeof business.slug !== "string"
        );

        const slugCounts = new Map();
        for (const business of data.businesses) {
          if (typeof business?.slug === "string") {
            slugCounts.set(business.slug, (slugCounts.get(business.slug) ?? 0) + 1);
          }
        }

        const duplicateSlugs = [...slugCounts.entries()]
          .filter(([, count]) => count > 1)
          .map(([slug]) => slug);

        const businessCount = data.businesses.length;
        const publishReadyCount = data.businesses.filter(
          (business) => business?.publish_ready === true
        ).length;

        const problems = [];
        if (missingNames.length) problems.push(`${missingNames.length} record(s) missing a business name.`);
        if (missingSlugs.length) problems.push(`${missingSlugs.length} record(s) missing a slug.`);
        if (duplicateSlugs.length) problems.push(`Duplicate slug(s): ${duplicateSlugs.join(", ")}`);
        if (data.business_count !== businessCount) {
          problems.push(`business_count says ${data.business_count}, but the array contains ${businessCount}.`);
        }
        if (data.publish_ready_count !== publishReadyCount) {
          problems.push(
            `publish_ready_count says ${data.publish_ready_count}, but ${publishReadyCount} records are publish-ready.`
          );
        }

        if (problems.length) {
          setResult("The JSON parsed, but validation found problems.", problems, false);
          return false;
        }

        validatedJson = data;
        publishButton.disabled = false;
        setResult(
          "Valid directory JSON. It is ready to publish.",
          [
            `${businessCount} total businesses`,
            `${publishReadyCount} publish-ready businesses`,
            "No missing business names",
            "No missing slugs",
            "No duplicate slugs",
            "Stored counts match the records"
          ],
          true
        );
        return true;
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unknown validation error.";
        setResult(`Invalid JSON: ${message}`, [], false);
        return false;
      }
    };

    input.addEventListener("input", () => {
      validatedJson = null;
      publishButton.disabled = true;
    });

    validateButton.addEventListener("click", validateDirectory);

    loadButton.addEventListener("click", async () => {
      loadButton.disabled = true;
      loadButton.textContent = "Loading…";

      try {
        const response = await fetch("/data/local-business-directory.json", { cache: "no-store" });
        if (!response.ok) throw new Error(`Request failed with status ${response.status}.`);
        const data = await response.json();
        input.value = JSON.stringify(data, null, 2);
        validateDirectory();
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unknown loading error.";
        setResult(`Could not load the current directory: ${message}`, [], false);
      } finally {
        loadButton.disabled = false;
        loadButton.textContent = "Load current JSON";
      }
    });

    publishButton.addEventListener("click", async () => {
      if (!validatedJson && !validateDirectory()) return;
      if (!adminKey.value) {
        setResult("Enter the admin key before publishing.", [], false);
        return;
      }

      publishButton.disabled = true;
      publishButton.textContent = "Publishing…";

      try {
        const response = await fetch("/api/publish-directory", {
          method: "POST",
          headers: {
            "content-type": "application/json",
            "x-admin-key": adminKey.value
          },
          body: JSON.stringify(validatedJson)
        });

        const result = await response.json();
        if (!response.ok) {
          const details = Array.isArray(result.problems) ? result.problems : [];
          setResult(result.error || `Publishing failed with status ${response.status}.`, details, false);
          return;
        }

        setResult(
          result.message || "Directory published successfully.",
          [
            `${result.business_count} total businesses committed`,
            `${result.publish_ready_count} publish-ready businesses committed`,
            result.commit ? `GitHub commit: ${result.commit.slice(0, 7)}` : "GitHub commit created"
          ],
          true
        );
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unknown publishing error.";
        setResult(`Publishing failed: ${message}`, [], false);
      } finally {
        publishButton.disabled = false;
        publishButton.textContent = "Publish";
      }
    });
  </script>
</BaseLayout>

<style>
  .publisher {
    width: min(960px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3rem 0 5rem;
  }

  header { margin-bottom: 1.5rem; }
  .eyebrow {
    margin: 0 0 0.35rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  h1 { margin: 0 0 0.75rem; }

  .panel {
    padding: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.05);
  }

  label {
    display: block;
    margin: 0.9rem 0 0.5rem;
    font-weight: 800;
  }

  input, textarea {
    width: 100%;
    padding: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 0.65rem;
    font: inherit;
  }

  textarea {
    min-height: 55vh;
    resize: vertical;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  button {
    min-height: 44px;
    padding: 0.7rem 1rem;
    border: 0;
    border-radius: 0.6rem;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  button.secondary {
    background: transparent;
    border: 1px solid currentColor;
  }

  button:disabled {
    cursor: not-allowed;
    opacity: 0.45;
  }

  .results {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
  }

  .results h2 { margin: 0 0 0.5rem; font-size: 1.05rem; }
  .results ul { margin-bottom: 0; }
  .success, .error { font-weight: 800; }

  @media (max-width: 640px) {
    .publisher { padding-top: 1.5rem; }
    .panel { padding: 0.85rem; }
    textarea { min-height: 58vh; }
    .actions button { flex: 1 1 100%; }
  }
</style>
