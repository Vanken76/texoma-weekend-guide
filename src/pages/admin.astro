---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Admin | Texoma Weekend Guide"
  description="Private publishing controls for the Texoma Weekend Guide."
>
  <section class="publisher">
    <header>
      <p class="eyebrow">TWG Admin</p>
      <h1>Texoma Weekend Guide Admin</h1>
      <p>Enter the admin key once, then use any publisher on this page.</p>
    </header>

    <section class="panel auth-panel">
      <label for="admin-key">Admin key</label>
      <input id="admin-key" type="password" autocomplete="current-password" placeholder="Enter your private publishing key" />
      <p class="helper">The key is saved only for this browser tab and clears when the tab closes.</p>
    </section>

    <section class="panel tool-panel">
      <div class="panel-heading">
        <p class="eyebrow">Directory Publisher</p>
        <h2>Business Directory JSON</h2>
        <p>Paste the complete directory JSON, validate it, then publish it directly to GitHub.</p>
      </div>

      <label for="json-input">Directory JSON</label>
      <textarea id="json-input" class="code-input directory-input" spellcheck="false" autocapitalize="off" autocomplete="off" placeholder='Paste the complete JSON here, beginning with { and ending with }'></textarea>

      <div class="actions">
        <button id="load-current" type="button" class="secondary">Load current JSON</button>
        <button id="validate-directory" type="button">Validate JSON</button>
        <button id="publish-directory" type="button" disabled>Publish Directory</button>
      </div>

      <section class="results" aria-live="polite">
        <h3>Directory status</h3>
        <p id="directory-status">Nothing has been validated yet.</p>
        <ul id="directory-checks"></ul>
      </section>
    </section>

    <section class="panel tool-panel">
      <div class="panel-heading">
        <p class="eyebrow">Roundup Publisher</p>
        <h2>Weekend Roundup</h2>
        <p>Choose the roundup image, enter a slug, and paste the complete Markdown file.</p>
      </div>

      <label for="roundup-slug">Roundup slug</label>
      <input id="roundup-slug" type="text" spellcheck="false" autocapitalize="off" autocomplete="off" placeholder="july-23-26-2026" />

      <label for="roundup-image">Roundup image</label>
      <input id="roundup-image" type="file" accept="image/jpeg,image/png,image/webp" />
      <div id="image-preview-wrap" class="image-preview-wrap" hidden>
        <img id="image-preview" alt="Selected roundup image preview" />
        <p id="image-details" class="helper"></p>
      </div>

      <label for="roundup-markdown">Roundup Markdown</label>
      <textarea id="roundup-markdown" class="code-input roundup-input" spellcheck="false" autocapitalize="off" autocomplete="off" placeholder={'---\ntitle: "Texoma Weekend Roundup — July 23–26, 2026"\ndescription: "..."\nstartDate: 2026-07-23\nendDate: 2026-07-26\nimage: "/images/july-23-26-roundup.jpg"\nfeatured: true\n---\n\n## Thursday\n\nRoundup content...'}></textarea>

      <div class="actions">
        <button id="validate-roundup" type="button">Validate Roundup</button>
        <button id="publish-roundup" type="button" disabled>Publish Roundup</button>
      </div>

      <section class="results" aria-live="polite">
        <h3>Roundup status</h3>
        <p id="roundup-status">Nothing has been validated yet.</p>
        <ul id="roundup-checks"></ul>
      </section>
    </section>
  </section>

  <script>
    const adminKey = document.querySelector("#admin-key");
    const directoryInput = document.querySelector("#json-input");
    const directoryStatus = document.querySelector("#directory-status");
    const directoryChecks = document.querySelector("#directory-checks");
    const validateDirectoryButton = document.querySelector("#validate-directory");
    const loadDirectoryButton = document.querySelector("#load-current");
    const publishDirectoryButton = document.querySelector("#publish-directory");

    const roundupSlug = document.querySelector("#roundup-slug");
    const roundupImage = document.querySelector("#roundup-image");
    const roundupMarkdown = document.querySelector("#roundup-markdown");
    const imagePreviewWrap = document.querySelector("#image-preview-wrap");
    const imagePreview = document.querySelector("#image-preview");
    const imageDetails = document.querySelector("#image-details");
    const validateRoundupButton = document.querySelector("#validate-roundup");
    const publishRoundupButton = document.querySelector("#publish-roundup");
    const roundupStatus = document.querySelector("#roundup-status");
    const roundupChecks = document.querySelector("#roundup-checks");

    if (
      !(adminKey instanceof HTMLInputElement) ||
      !(directoryInput instanceof HTMLTextAreaElement) ||
      !(directoryStatus instanceof HTMLElement) ||
      !(directoryChecks instanceof HTMLUListElement) ||
      !(validateDirectoryButton instanceof HTMLButtonElement) ||
      !(loadDirectoryButton instanceof HTMLButtonElement) ||
      !(publishDirectoryButton instanceof HTMLButtonElement) ||
      !(roundupSlug instanceof HTMLInputElement) ||
      !(roundupImage instanceof HTMLInputElement) ||
      !(roundupMarkdown instanceof HTMLTextAreaElement) ||
      !(imagePreviewWrap instanceof HTMLElement) ||
      !(imagePreview instanceof HTMLImageElement) ||
      !(imageDetails instanceof HTMLElement) ||
      !(validateRoundupButton instanceof HTMLButtonElement) ||
      !(publishRoundupButton instanceof HTMLButtonElement) ||
      !(roundupStatus instanceof HTMLElement) ||
      !(roundupChecks instanceof HTMLUListElement)
    ) {
      throw new Error("Admin publisher controls could not be initialized.");
    }

    const savedKey = sessionStorage.getItem("twg-admin-key");
    if (savedKey) adminKey.value = savedKey;
    adminKey.addEventListener("input", () => {
      if (adminKey.value) sessionStorage.setItem("twg-admin-key", adminKey.value);
      else sessionStorage.removeItem("twg-admin-key");
    });

    let validatedJson = null;
    let roundupValidated = false;

    const setResult = (statusElement, checksElement, message, items = [], valid = false) => {
      statusElement.textContent = message;
      statusElement.className = valid ? "success" : "error";
      checksElement.replaceChildren();
      for (const item of items) {
        const li = document.createElement("li");
        li.textContent = item;
        checksElement.appendChild(li);
      }
    };

    const validateDirectory = () => {
      validatedJson = null;
      publishDirectoryButton.disabled = true;

      try {
        const data = JSON.parse(directoryInput.value);
        if (!data || typeof data !== "object" || Array.isArray(data)) throw new Error("The top level must be a JSON object.");
        if (!Array.isArray(data.businesses)) throw new Error('The JSON must contain a "businesses" array.');

        const missingNames = data.businesses.filter((business) => !business?.business_name || typeof business.business_name !== "string");
        const missingSlugs = data.businesses.filter((business) => !business?.slug || typeof business.slug !== "string");
        const slugCounts = new Map();
        for (const business of data.businesses) {
          if (typeof business?.slug === "string") slugCounts.set(business.slug, (slugCounts.get(business.slug) ?? 0) + 1);
        }
        const duplicateSlugs = [...slugCounts.entries()].filter(([, count]) => count > 1).map(([slug]) => slug);
        const businessCount = data.businesses.length;
        const publishReadyCount = data.businesses.filter((business) => business?.publish_ready === true).length;

        const problems = [];
        if (missingNames.length) problems.push(`${missingNames.length} record(s) missing a business name.`);
        if (missingSlugs.length) problems.push(`${missingSlugs.length} record(s) missing a slug.`);
        if (duplicateSlugs.length) problems.push(`Duplicate slug(s): ${duplicateSlugs.join(", ")}`);
        if (data.business_count !== businessCount) problems.push(`business_count says ${data.business_count}, but the array contains ${businessCount}.`);
        if (data.publish_ready_count !== publishReadyCount) problems.push(`publish_ready_count says ${data.publish_ready_count}, but ${publishReadyCount} records are publish-ready.`);

        if (problems.length) {
          setResult(directoryStatus, directoryChecks, "The JSON parsed, but validation found problems.", problems, false);
          return false;
        }

        validatedJson = data;
        publishDirectoryButton.disabled = false;
        setResult(directoryStatus, directoryChecks, "Valid directory JSON. It is ready to publish.", [
          `${businessCount} total businesses`,
          `${publishReadyCount} publish-ready businesses`,
          "No missing business names",
          "No missing slugs",
          "No duplicate slugs",
          "Stored counts match the records"
        ], true);
        return true;
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unknown validation error.";
        setResult(directoryStatus, directoryChecks, `Invalid JSON: ${message}`, [], false);
        return false;
      }
    };

    directoryInput.addEventListener("input", () => {
      validatedJson = null;
      publishDirectoryButton.disabled = true;
    });
    validateDirectoryButton.addEventListener("click", validateDirectory);

    loadDirectoryButton.addEventListener("click", async () => {
      loadDirectoryButton.disabled = true;
      loadDirectoryButton.textContent = "Loading…";
      try {
        const response = await fetch("/data/local-business-directory.json", { cache: "no-store" });
        if (!response.ok) throw new Error(`Request failed with status ${response.status}.`);
        const data = await response.json();
        directoryInput.value = JSON.stringify(data, null, 2);
        validateDirectory();
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unknown loading error.";
        setResult(directoryStatus, directoryChecks, `Could not load the current directory: ${message}`, [], false);
      } finally {
        loadDirectoryButton.disabled = false;
        loadDirectoryButton.textContent = "Load current JSON";
      }
    });

    publishDirectoryButton.addEventListener("click", async () => {
      if (!validatedJson && !validateDirectory()) return;
      if (!adminKey.value) {
        setResult(directoryStatus, directoryChecks, "Enter the admin key before publishing.", [], false);
        adminKey.focus();
        return;
      }
      publishDirectoryButton.disabled = true;
      publishDirectoryButton.textContent = "Publishing…";
      try {
        const response = await fetch("/api/publish-directory", {
          method: "POST",
          headers: { "content-type": "application/json", "x-admin-key": adminKey.value },
          body: JSON.stringify(validatedJson)
        });
        const result = await response.json();
        if (!response.ok) {
          const details = Array.isArray(result.problems) ? result.problems : [];
          setResult(directoryStatus, directoryChecks, result.error || `Publishing failed with status ${response.status}.`, details, false);
          return;
        }
        setResult(directoryStatus, directoryChecks, result.message || "Directory published successfully.", [
          `${result.business_count} total businesses committed`,
          `${result.publish_ready_count} publish-ready businesses committed`,
          result.commit ? `GitHub commit: ${result.commit.slice(0, 7)}` : "GitHub commit created"
        ], true);
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unknown publishing error.";
        setResult(directoryStatus, directoryChecks, `Publishing failed: ${message}`, [], false);
      } finally {
        publishDirectoryButton.disabled = false;
        publishDirectoryButton.textContent = "Publish Directory";
      }
    });

    const resetRoundupValidation = () => {
      roundupValidated = false;
      publishRoundupButton.disabled = true;
    };

    roundupImage.addEventListener("change", () => {
      resetRoundupValidation();
      const file = roundupImage.files?.[0];
      imagePreviewWrap.hidden = !file;
      if (!file) {
        imagePreview.removeAttribute("src");
        imageDetails.textContent = "";
        return;
      }
      imagePreview.src = URL.createObjectURL(file);
      imageDetails.textContent = `${file.name} — ${(file.size / 1024 / 1024).toFixed(2)} MB`;
    });

    const frontmatterValue = (frontmatter, key) => {
      const match = frontmatter.match(new RegExp(`^${key}:\\s*["']?(.+?)["']?\\s*$`, "m"));
      return match?.[1]?.trim() ?? "";
    };

    const validateRoundup = () => {
      resetRoundupValidation();
      const slug = roundupSlug.value.trim();
      const markdown = roundupMarkdown.value.trim();
      const file = roundupImage.files?.[0];
      const problems = [];

      if (!/^[a-z0-9]+(?:-[a-z0-9]+)*$/.test(slug)) problems.push("Slug must use lowercase letters, numbers, and single hyphens only.");
      if (!file) problems.push("Choose a roundup image.");
      if (file && !["image/jpeg", "image/png", "image/webp"].includes(file.type)) problems.push("Image must be a JPG, PNG, or WebP file.");
      if (file && file.size > 8 * 1024 * 1024) problems.push("Image must be 8 MB or smaller.");
      if (!markdown.startsWith("---\n")) problems.push("Markdown must begin with a frontmatter delimiter (---).");

      const closingIndex = markdown.indexOf("\n---", 4);
      if (closingIndex < 0) problems.push("Markdown is missing the closing frontmatter delimiter.");

      if (!problems.length) {
        const frontmatter = markdown.slice(4, closingIndex);
        const body = markdown.slice(closingIndex + 4).trim();
        const title = frontmatterValue(frontmatter, "title");
        const description = frontmatterValue(frontmatter, "description");
        const startDate = frontmatterValue(frontmatter, "startDate");
        const endDate = frontmatterValue(frontmatter, "endDate");
        const imagePath = frontmatterValue(frontmatter, "image");

        if (!title) problems.push("Frontmatter is missing title.");
        if (!description) problems.push("Frontmatter is missing description.");
        if (!/^\d{4}-\d{2}-\d{2}$/.test(startDate)) problems.push("startDate must use YYYY-MM-DD.");
        if (!/^\d{4}-\d{2}-\d{2}$/.test(endDate)) problems.push("endDate must use YYYY-MM-DD.");
        if (startDate && endDate && endDate < startDate) problems.push("endDate cannot be before startDate.");
        if (!imagePath.startsWith("/images/")) problems.push('The image path must begin with "/images/".');
        if (file && imagePath !== `/images/${file.name}`) problems.push(`Frontmatter image must be exactly /images/${file.name}.`);
        if (!body) problems.push("The roundup body is empty.");
        if (!/^##\s+/m.test(body)) problems.push("The roundup body needs at least one ## section heading.");
      }

      if (problems.length) {
        setResult(roundupStatus, roundupChecks, "Roundup validation found problems.", problems, false);
        return false;
      }

      roundupValidated = true;
      publishRoundupButton.disabled = false;
      setResult(roundupStatus, roundupChecks, "Valid roundup content. It is ready to publish.", [
        `Slug: ${slug}`,
        `Image: ${file.name}`,
        "Required frontmatter is present",
        "Dates are valid",
        "Image path matches the selected file",
        "Roundup body contains at least one section"
      ], true);
      return true;
    };

    roundupSlug.addEventListener("input", resetRoundupValidation);
    roundupMarkdown.addEventListener("input", resetRoundupValidation);
    validateRoundupButton.addEventListener("click", validateRoundup);

    publishRoundupButton.addEventListener("click", async () => {
      if (!roundupValidated && !validateRoundup()) return;
      if (!adminKey.value) {
        setResult(roundupStatus, roundupChecks, "Enter the admin key before publishing.", [], false);
        adminKey.focus();
        return;
      }

      const file = roundupImage.files?.[0];
      if (!file) {
        setResult(roundupStatus, roundupChecks, "Choose a roundup image before publishing.", [], false);
        return;
      }

      const formData = new FormData();
      formData.append("slug", roundupSlug.value.trim());
      formData.append("markdown", roundupMarkdown.value.trim());
      formData.append("image", file, file.name);

      publishRoundupButton.disabled = true;
      publishRoundupButton.textContent = "Publishing…";

      try {
        const response = await fetch("/api/publish-roundup", {
          method: "POST",
          headers: { "x-admin-key": adminKey.value },
          body: formData
        });

        let result;
        try {
          result = await response.json();
        } catch {
          throw new Error(`Publisher returned an unreadable response (${response.status}).`);
        }

        if (!response.ok) {
          const details = Array.isArray(result.problems) ? result.problems : [];
          setResult(roundupStatus, roundupChecks, result.error || `Publishing failed with status ${response.status}.`, details, false);
          return;
        }

        roundupValidated = false;
        setResult(roundupStatus, roundupChecks, result.message || "Roundup published successfully.", [
          result.roundup_path ? `Roundup: ${result.roundup_path}` : `Roundup slug: ${roundupSlug.value.trim()}`,
          result.image_path ? `Image: ${result.image_path}` : `Image: ${file.name}`,
          result.roundup_commit ? `Roundup commit: ${result.roundup_commit.slice(0, 7)}` : "Roundup commit created",
          result.image_commit ? `Image commit: ${result.image_commit.slice(0, 7)}` : "Image commit created"
        ], true);
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unknown publishing error.";
        setResult(roundupStatus, roundupChecks, `Publishing failed: ${message}`, [], false);
      } finally {
        publishRoundupButton.disabled = !roundupValidated;
        publishRoundupButton.textContent = "Publish Roundup";
      }
    });
  </script>
</BaseLayout>

<style>
  .publisher { width: min(960px, calc(100% - 2rem)); margin: 0 auto; padding: 3rem 0 5rem; }
  header { margin-bottom: 1.5rem; }
  .eyebrow { margin: 0 0 0.35rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; }
  h1, h2, h3 { margin-top: 0; }
  h1 { margin-bottom: 0.75rem; }
  h2 { margin-bottom: 0.5rem; }
  .panel { padding: 1.25rem; border: 1px solid rgba(255, 255, 255, 0.16); border-radius: 1rem; background: rgba(255, 255, 255, 0.05); }
  .tool-panel { margin-top: 1.25rem; }
  .panel-heading { margin-bottom: 1rem; }
  .panel-heading p:last-child { margin-bottom: 0; }
  label { display: block; margin: 0.9rem 0 0.5rem; font-weight: 800; }
  input, textarea { width: 100%; padding: 0.9rem; border: 1px solid rgba(255, 255, 255, 0.22); border-radius: 0.65rem; font: inherit; }
  .code-input { resize: vertical; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 0.82rem; line-height: 1.45; }
  .directory-input { min-height: 55vh; }
  .roundup-input { min-height: 42vh; }
  .helper { margin: 0.5rem 0 0; font-size: 0.9rem; opacity: 0.78; }
  .image-preview-wrap { margin-top: 0.8rem; padding: 0.75rem; border: 1px solid rgba(255, 255, 255, 0.14); border-radius: 0.75rem; }
  .image-preview-wrap img { display: block; width: min(100%, 520px); max-height: 320px; object-fit: contain; border-radius: 0.5rem; }
  .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1rem; }
  button { min-height: 44px; padding: 0.7rem 1rem; border: 0; border-radius: 0.6rem; font: inherit; font-weight: 800; cursor: pointer; }
  button.secondary { background: transparent; border: 1px solid currentColor; }
  button:disabled { cursor: not-allowed; opacity: 0.45; }
  .results { margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid rgba(255, 255, 255, 0.14); }
  .results h3 { margin-bottom: 0.5rem; font-size: 1.05rem; }
  .results ul { margin-bottom: 0; }
  .success, .error { font-weight: 800; }
  @media (max-width: 640px) {
    .publisher { padding-top: 1.5rem; }
    .panel { padding: 0.85rem; }
    .directory-input { min-height: 58vh; }
    .roundup-input { min-height: 50vh; }
    .actions button { flex: 1 1 100%; }
  }
</style>
