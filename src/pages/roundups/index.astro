---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const roundups = (await getCollection("roundups")).sort(
  (a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf()
);
---

<BaseLayout
  title="Texoma Weekend Roundup | Texoma Weekend Guide"
  description="Browse Texoma Weekend Guide roundups featuring live music, family events, food, festivals, lake activities, and community happenings."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Plan ahead</p>
      <h1>Weekend Roundups</h1>
      <p>Find something worth leaving the house for.</p>
    </div>
  </section>

  <section class="section roundup-list">
    <div class="container">
      {roundups.length === 0 ? (
        <div class="empty-state">
          <h2>The next Weekend Roundup is coming soon.</h2>
        </div>
      ) : (
        <div class="card-grid">
          {roundups.map((roundup) => (
            <article class="card roundup-card">
              <div class="roundup-image-wrap">
                <img
                  class="card-image"
                  src={roundup.data.image}
                  alt={roundup.data.title}
                />
              </div>

              <div class="card-content">
                <p class="eyebrow">Weekend Roundup</p>
                <h2>{roundup.data.title}</h2>
                <p class="roundup-description">{roundup.data.description}</p>

                <a
                  class="button"
                  href={`/roundups/${roundup.id}/`}
                >
                  Read Roundup
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .roundup-list {
    padding-top: 2.5rem;
  }

  .roundup-card {
    display: flex;
    flex-direction: column;
  }

  .roundup-image-wrap {
    display: grid;
    place-items: center;
    height: 260px;
    padding: 0.75rem;
    overflow: hidden;
    background: #eef3f4;
  }

  .roundup-card .card-image {
    width: 100%;
    height: 100%;
    aspect-ratio: auto;
    object-fit: contain;
    object-position: center;
  }

  .roundup-card .card-content {
    padding: 1.15rem 1.2rem 1.3rem;
  }

  .roundup-card .card-content h2 {
    margin-bottom: 0.75rem;
    font-size: clamp(1.45rem, 3vw, 2rem);
  }

  .roundup-description {
    margin-bottom: 1.15rem;
    font-size: 1rem;
    line-height: 1.5;
  }

  @media (max-width: 820px) {
    .roundup-list {
      padding-top: 1.5rem;
    }

    .roundup-image-wrap {
      height: 210px;
      padding: 0.5rem;
    }

    .roundup-card .card-content {
      padding: 1rem;
    }

    .roundup-card .card-content h2 {
      font-size: 1.55rem;
    }

    .roundup-description {
      font-size: 0.98rem;
    }

    .roundup-card .button {
      width: 100%;
    }
  }
</style>
