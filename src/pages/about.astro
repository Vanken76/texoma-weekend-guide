---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About Texoma Weekend Guide"
  description="Learn about Texoma Weekend Guide, an independent local guide covering events, food, live music, lake days, businesses, and communities around Texoma."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Independent local coverage</p>
      <h1>About Texoma Weekend Guide</h1>

      <p>
        Built locally to help people discover more of Texoma.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container prose">
      <h2>Discover Local. Make Memories.</h2>

      <p>
        Texoma Weekend Guide helps residents and visitors find
        events, live music, family activities, lake-day ideas,
        restaurants, small businesses, fundraisers, and community
        happenings across North Texas and southern Oklahoma.
      </p>

      <p>
        Coverage may include Denison, Sherman, Pottsboro,
        Gainesville, Whitesboro, Bonham, Durant, Tishomingo,
        Lake Texoma, and surrounding communities.
      </p>

      <h2>Community first</h2>

      <p>
        The goal is not to promote only the largest venues or
        loudest pages. TWG looks for useful, interesting,
        affordable, unusual, and locally meaningful things
        happening throughout the region.
      </p>

      <h2>Independent and inclusive</h2>

      <p>
        Texoma Weekend Guide is an independent local publication.
        Sharing an event or business does not necessarily represent
        an endorsement. Civic and political events are shared for
        informational purposes without endorsing candidates or parties.
      </p>

      <div class="button-row">
        <a class="button" href="/submit/">
          Submit an Event
        </a>

        <a
          class="button outline"
          href="mailto:texomaweekendguide@gmail.com"
        >
          Contact TWG
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
